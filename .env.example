# Peaker — örnek ortam (değerleri kendi Supabase projenizle doldurun).
# Kopyalayın: cp .env.example .env.local

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
# Yalnızca sunucu: server actions, admin client, migrasyon onarımları — asla istemciye koymayın.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# --- İsteğe bağlı: Sentry (yoksa uygulama normal çalışır) ---
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# NEXT_PUBLIC_SENTRY_ENABLED=1
# NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
# Yerel geliştirmede Sentry'e göndermek için: NEXT_PUBLIC_SENTRY_DEV=1
# Kaynak haritası (CI): SENTRY_AUTH_TOKEN, SENTRY_ORG, SENTRY_PROJECT
